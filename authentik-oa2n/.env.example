# Copy to .env and adjust values before running docker compose.

# Base domain for Traefik Host() rules (must match your public DNS zone).
TRAEFIK_HOST=example.com

# Traefik hostname will be: ${COMPOSE_PROJECT_NAME}.${TRAEFIK_HOST}
# COMPOSE_PROJECT_NAME is the compose project name (usually the directory name,
# e.g. authentik-oa2n -> authentik-oa2n.example.com). Create a DNS record for it.

# PostgreSQL password for the Authentik database user.
POSTGRES_PASSWORD=change-me-strong-random

# Authentik secret key (generate a long random string, e.g. openssl rand -base64 48).
SECRET_KEY=change-me-long-random-secret
