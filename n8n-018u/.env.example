# Copy to .env and adjust values before running docker compose.

# Base domain for Traefik Host() rules (must match your public DNS zone).
TRAEFIK_HOST=example.com

# Public hostname for n8n will be: ${TRAEFIK_SUBDOMAIN}.${TRAEFIK_HOST}
# Defaults to "n8n" if unset (e.g. n8n.example.com).
TRAEFIK_SUBDOMAIN=n8n

# Timezone for the n8n container (IANA name).
TZ=Europe/Berlin
